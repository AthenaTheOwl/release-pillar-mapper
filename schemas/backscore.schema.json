{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/release-pillar-mapper/backscore.schema.json",
  "title": "Backscore Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release_id",
    "scored_at",
    "scores"
  ],
  "properties": {
    "release_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "scored_at": {
      "type": "string",
      "format": "date-time"
    },
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "axis",
          "target_id",
          "predicted_direction",
          "realized_direction",
          "lag_days",
          "notes"
        ],
        "properties": {
          "axis": {
            "type": "string",
            "enum": ["repo", "brief", "pillar"]
          },
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "predicted_direction": {
            "type": "string",
            "minLength": 1
          },
          "realized_direction": {
            "type": "string",
            "minLength": 1
          },
          "lag_days": {
            "type": "integer",
            "minimum": 0
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
