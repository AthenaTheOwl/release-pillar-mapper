{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/release-pillar-mapper/release_event.schema.json",
  "title": "Release Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "source_url",
    "vendor",
    "headline",
    "claims",
    "ingested_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "kind": {
      "type": "string",
      "enum": ["model", "eval", "dataset", "framework"]
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "vendor": {
      "type": "string",
      "minLength": 1
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "source_anchor"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "source_anchor": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
